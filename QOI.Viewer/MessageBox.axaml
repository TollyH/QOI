<Window x:Class="QOI.Viewer.MessageBox"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" SizeToContent="WidthAndHeight">
    <Grid ColumnDefinitions="Auto 1*" RowDefinitions="1* Auto">
        <Image x:Name="imageIcon" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" Width="32" Height="32"/>
        <TextBlock x:Name="messageText" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center"/>
        <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" HorizontalContentAlignment="Center" Margin="5" Width="100" Content="OK" Click="Button_Click"/>
    </Grid>
</Window>
