<UserControl x:Class="QOI.Viewer.FileProgress"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <TextBlock x:Name="fileNameLabel" VerticalAlignment="Center" HorizontalAlignment="Left" d:Text="FileName.png" Margin="5" FontSize="14"/>
        <Ellipse x:Name="finishedIndicator" VerticalAlignment="Center" HorizontalAlignment="Right" Stroke="Black" StrokeThickness="1" Width="20" Height="20" Margin="5"/>
    </Grid>
</UserControl>
